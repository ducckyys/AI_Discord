# Required Discord credentials. Never commit your real token.
DISCORD_TOKEN=your_bot_token
CLIENT_ID=your_discord_application_id

# Optional: use a development server ID for commands that update immediately.
# Leave empty to register commands globally.
GUILD_ID=your_development_server_id

# Local SQLite database used for settings and conversation memory.
DATABASE_URL="file:./dev.db"

# Local LM Studio server and fallback model identifier.
LMSTUDIO_URL=http://localhost:1234/v1
AI_PROVIDER=lmstudio
MODEL=qwen3

# Optional Discord user ID displayed by /about.
CREATOR_ID=

# Optional SearXNG configuration for the /search command.
SEARXNG_URL=http://127.0.0.1:8080
SEARXNG_TIMEOUT_MS=10000
SEARXNG_MAX_RESULTS=5

# Runtime logging and the local GET /health endpoint.
LOG_LEVEL=info
PORT=3000
