{
  "compilerOptions": {
    "target": "ES2022", "module": "NodeNext", "moduleResolution": "NodeNext",
    "lib": ["ES2022"], "strict": true, "noUncheckedIndexedAccess": true,
    "esModuleInterop": true, "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true, "outDir": "./dist", "rootDir": "./src",
    "resolveJsonModule": true, "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"], "exclude": ["node_modules", "dist", "tests"]
}
