{
  "name": "duccky-ai",
  "version": "1.0.0",
  "private": true,
  "description": "A Discord AI bot powered exclusively by LM Studio.",
  "type": "module",
  "engines": { "node": ">=22.0.0", "pnpm": ">=9.0.0" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc --build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "deploy:commands": "tsx src/deployCommands.ts"
  },
  "keywords": ["discord", "ai", "lm-studio", "typescript"],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.4.1",
    "pino": "^9.11.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "prisma": "^6.7.0",
    "tsx": "^4.19.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "prisma": { "seed": "tsx prisma/seed.ts" }
}
